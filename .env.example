# AWS S3 Source Settings
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name

# Azure Storage Destination Settings
AZURE_STORAGE_ACCOUNT=sasonestorage
AZURE_CONTAINER_NAME=sasonemediacontainer
AZURE_SAS_TOKEN=your-expiring-scoped-container-sas-token

# MySQL State Store Settings
# Set MYSQL_HOST=na to run in local SQLite fallback mode
MYSQL_HOST=sasoneazdb.mysql.database.azure.com
MYSQL_PORT=3306
MYSQL_USER=Azure_Dev_1
MYSQL_PASSWORD=your-password
MYSQL_DB=SASONE
MIGRATION_JOB_NAME=s3-to-azure-prod-final

# Verification & Orchestrator Settings
VERIFY_SAMPLE_OR_FULL=full
VERIFY_SAMPLE_PERCENT=10
REPORT_DIR=./reports
LOG_PATH=./orchestrator.log

# AzCopy Tuning (Optional environment variables referenced by AzCopy)
# AZCOPY_CONCURRENCY_VALUE=AUTO
# AZCOPY_LOG_LOCATION=/var/log/azcopy
# AZCOPY_JOB_PLAN_LOCATION=/var/azcopy-plans
